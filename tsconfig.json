{
  "include": ["vite.config.ts", "./resources/client/**/*.ts", "./resources/client/**/*.vue"],
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "types": ["vite/client", "./env.d.ts"],
    "paths": {
      "@components/*": ["./resources/client/components/*"],
      "@vendor/*": ["./vendor/*"]
    }
  }
}
